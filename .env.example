# Ghostwork — Environment Variables

# Server
GHOSTWORK_PORT=3100
GHOSTWORK_HOST=0.0.0.0
GHOSTWORK_MODE=local_trusted  # local_trusted | authenticated
GHOSTWORK_LOG_LEVEL=info

# Database (optional — uses embedded PostgreSQL if not set)
# DATABASE_URL=postgresql://user:password@localhost:5432/ghostwork

# Auth
GHOSTWORK_AGENT_JWT_SECRET=change-me-in-production
GHOSTWORK_AUTH_SECRET=change-me-in-production
GHOSTWORK_SECRETS_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Migrations
GHOSTWORK_MIGRATION_AUTO_APPLY=true
